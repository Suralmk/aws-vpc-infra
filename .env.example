POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=appdb
POSTGRES_PORT=5432
API_PORT=8000

# For running the app locally (outside Docker)
DATABASE_URL=postgresql://postgres:password@localhost:5432/appdb

# Docker Compose builds DATABASE_URL for the api service from POSTGRES_* vars above.

# Production (EC2 / docker-compose.prod.yml) — match terraform output db_secret_name
ENV=development
AWS_REGION=us-east-1
SECRET_NAME=production/db/credentials
ECR_IMAGE=130063747652.dkr.ecr.us-east-1.amazonaws.com/production-aws-vpc-infra-api:latest