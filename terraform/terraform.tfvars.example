# terraform.tfvars.example
# Copy to terraform.tfvars (gitignored) and fill in every value.
# See README.md "Step-by-step guide" for SSH key generation and bastion access.

region = "us-east-1"

environment = "dev"

db_password = "CHANGE_ME"

# Your public IP — run: curl ifconfig.me  then append /32
bastion_allowed_cidr = "YOUR_IP/32"

# Paste full output of: cat ~/.ssh/deployer-key.pub  (single line, in quotes)
public_key = "ssh-rsa AAAA... your-email@example.com"