# Remote state for Terraform (CI/CD and team use).
# First-time setup: create the bucket/table (see README), then run:
#   terraform init -migrate-state
terraform {
  required_version = ">= 1.5"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = ">= 5.0"
    }
  }

  backend "s3" {
    bucket         = "aws-vpc-infra-tfstate"
    key            = "production/terraform.tfstate"
    region         = "us-east-1"
    dynamodb_table = "terraform-locks"
    encrypt        = true
  }
}
